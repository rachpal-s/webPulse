# ── Crawler ─────────────────────────────────────────────────────────────
CRAWL_QUEUE_ENABLED=false
CRAWL_QUEUE_INTERVAL_MINS=45   # how often to crawl
CRAWL_QUEUE_START_HOUR=6       # don't crawl before 6am
CRAWL_QUEUE_END_HOUR=21        # don't crawl after 9pm
CRAWL_WINDOW_HOURS=4           # only articles from last 4h
CRAWL_MIN_SCORE=0.70           # relevance threshold
CRAWL_TOP_N=15 

# Options: ollama | google | openai | cohere | jina
EMBED_PROVIDER=jina
# nomic-embed-text=768, mxbai=1024, minilm=384, jina 1024
EMBED_DIMENSIONS=1024

JINA_EMBED_MODEL=jina-embeddings-v3

# Google (text-embedding-004 — 768 dims, free tier, recommended)
GOOGLE_EMBED_MODEL=gemini-embedding-001



GOOGLE_API_KEY=
JINA_API_KEY=