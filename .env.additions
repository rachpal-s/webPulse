# ── Crawler ─────────────────────────────────────────────────────────────
CRAWL_QUEUE_ENABLED=false
CRAWL_QUEUE_INTERVAL_MINS=45   # how often to crawl
CRAWL_QUEUE_START_HOUR=6       # don't crawl before 6am
CRAWL_QUEUE_END_HOUR=21        # don't crawl after 9pm
CRAWL_WINDOW_HOURS=4           # only articles from last 4h
CRAWL_MIN_SCORE=0.70           # relevance threshold
CRAWL_TOP_N=15 