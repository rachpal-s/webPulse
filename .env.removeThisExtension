# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_INFERENCE_URL=https://ollama.com          # Remote inference endpoint
OLLAMA_EMBED_URL=http://localhost:11434              # Local embeddings endpoint
OLLAMA_INFERENCE_MODEL=gemma3:4b                      # Model for chat/Q&A
OLLAMA_EMBED_MODEL=nomic-embed-text                  # Model for embeddings

# ── RAG thresholds ────────────────────────────────────────────────────────────
RAG_SMALL_THRESHOLD=2000        # words: use direct context (no chunking)
RAG_MEDIUM_THRESHOLD=15000      # words: semantic chunking + vector search
                                # above MEDIUM_THRESHOLD → full RAG pipeline

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_BREAKPOINT_TYPE=percentile        # percentile | standard_deviation | interquartile
CHUNK_BREAKPOINT_THRESHOLD=95           # percentile threshold for semantic splits
CHUNK_MIN_SIZE=150                      # min words per chunk
CHUNK_MAX_SIZE=800                      # max words per chunk

# ── SQLite vector store ───────────────────────────────────────────────────────
DB_PATH=data/webpulse.db                # SQLite DB path (relative to app root)
EMBED_DIMENSIONS=768                    # nomic-embed-text=768, mxbai=1024, minilm=384

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_TIMEOUT=28                      # HTTP timeout seconds
SCRAPER_MAX_HEADLINES=50                # Max headlines to extract from homepage
PLAYWRIGHT_WAIT_SECONDS=4              # Default JS wait time
PLAYWRIGHT_HEADLESS=true

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_TITLE=WebPulse

# ── Morning briefs ───────────────────────────────────────────────────────────────────────
BRIEF_AUTO_RUN=false
PORTFOLIO_ANALYSIS_ENABLED=false
PORTFOLIO_SYMBOLS=
BRIEF_PROMPTS_JSON=

# ── Morning Brief Batch ───────────────────────────────────────────────────────
BRIEF_START_TIME=08:15                  
BRIEF_ARTICLES_PER_SITE=12
BRIEF_TIMEZONE=Asia/Kolkata
 
# ── SMTP (for email delivery) ─────────────────────────────────────────────────
SMTP_HOST=smtppro.zoho.in
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_ENABLED=true



OLLAMA_INFERENCE_API_KEY=
OLLAMA_EMBED_API_KEY=""